{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/backend-api/(.*)", "destination": "/api/index" },
    { "source": "/health", "destination": "/health" },
    { "source": "/ping", "destination": "/ping" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
